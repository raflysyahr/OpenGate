#include <stdio.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "esp_err.h"
#include "driver/i2c.h"
#include "rom/ets_sys.h"

/* ================= CONFIG ================= */

#define LCD_I2C_ADDR   0x27

/* PCF8574 → LCD mapping (STANDARD MARKET MODULE) */

#define LCD_RS         (1 << 0)   // P0
#define LCD_RW         (1 << 1)   // P1 (always LOW)
#define LCD_ENABLE     (1 << 2)   // P2
#define LCD_BACKLIGHT (1 << 3)   // P3

#define LCD_D4         (1 << 4)   // P4
#define LCD_D5         (1 << 5)   // P5
#define LCD_D6         (1 << 6)   // P6
#define LCD_D7         (1 << 7)   // P7

#define I2C_TIMEOUT_MS 1000

/* ================= STRUCT ================= */

typedef struct {
    i2c_port_t port;
} lcd1602_t;

/* ================= LOW LEVEL ================= */

static esp_err_t lcd_write_byte(lcd1602_t *lcd, uint8_t data)
{
    i2c_cmd_handle_t cmd = i2c_cmd_link_create();

    i2c_master_start(cmd);
    i2c_master_write_byte(cmd, (LCD_I2C_ADDR << 1) | I2C_MASTER_WRITE, true);
    i2c_master_write_byte(cmd, data & ~LCD_RW, true);
    i2c_master_stop(cmd);

    esp_err_t ret = i2c_master_cmd_begin(
        lcd->port, cmd, pdMS_TO_TICKS(I2C_TIMEOUT_MS)
    );

    i2c_cmd_link_delete(cmd);
    return ret;
}

static void lcd_pulse(lcd1602_t *lcd, uint8_t data)
{
    lcd_write_byte(lcd, data | LCD_ENABLE);
    ets_delay_us(1);
    lcd_write_byte(lcd, data & ~LCD_ENABLE);
    ets_delay_us(50);
}

static void lcd_send_nibble(lcd1602_t *lcd, uint8_t nibble, uint8_t mode)
{
    uint8_t data = 0;

    if (nibble & 0x01) data |= LCD_D4;
    if (nibble & 0x02) data |= LCD_D5;
    if (nibble & 0x04) data |= LCD_D6;
    if (nibble & 0x08) data |= LCD_D7;

    data |= mode | LCD_BACKLIGHT;

    lcd_pulse(lcd, data);
}

static void lcd_send_byte(lcd1602_t *lcd, uint8_t val, uint8_t mode)
{
    lcd_send_nibble(lcd, val >> 4, mode);
    lcd_send_nibble(lcd, val & 0x0F, mode);
}

static inline void lcd_cmd(lcd1602_t *lcd, uint8_t cmd)
{
    lcd_send_byte(lcd, cmd, 0);
}

static inline void lcd_data(lcd1602_t *lcd, uint8_t data)
{
    lcd_send_byte(lcd, data, LCD_RS);
}

/* ================= PUBLIC API ================= */

esp_err_t lcd1602_init(lcd1602_t *lcd, i2c_port_t port,
                       gpio_num_t sda, gpio_num_t scl)
{
    static bool i2c_installed = false;

    lcd->port = port;

    if (!i2c_installed) {
        i2c_config_t conf = {
            .mode = I2C_MODE_MASTER,
            .sda_io_num = sda,
            .scl_io_num = scl,
            .sda_pullup_en = GPIO_PULLUP_ENABLE,
            .scl_pullup_en = GPIO_PULLUP_ENABLE,
            .master.clk_speed = 100000
        };

        ESP_ERROR_CHECK(i2c_param_config(port, &conf));
        ESP_ERROR_CHECK(i2c_driver_install(port, conf.mode, 0, 0, 0));

        i2c_installed = true;
    }

    vTaskDelay(pdMS_TO_TICKS(50));

    /* HD44780 Init Sequence */

    lcd_send_nibble(lcd, 0x03, 0);
    vTaskDelay(pdMS_TO_TICKS(5));
    lcd_send_nibble(lcd, 0x03, 0);
    ets_delay_us(150);
    lcd_send_nibble(lcd, 0x03, 0);
    lcd_send_nibble(lcd, 0x02, 0);

    lcd_cmd(lcd, 0x28);   // 4bit, 2 line
    lcd_cmd(lcd, 0x08);   // display off
    lcd_cmd(lcd, 0x01);   // clear
    vTaskDelay(pdMS_TO_TICKS(3));
    lcd_cmd(lcd, 0x06);   // entry mode
    lcd_cmd(lcd, 0x0C);   // display on

    return ESP_OK;
}

void lcd1602_clear(lcd1602_t *lcd)
{
    lcd_cmd(lcd, 0x01);
    vTaskDelay(pdMS_TO_TICKS(3));
}

void lcd1602_set_cursor(lcd1602_t *lcd, uint8_t col, uint8_t row)
{
    static const uint8_t row_offsets[] = {0x00, 0x40};
    lcd_cmd(lcd, 0x80 | (col + row_offsets[row & 1]));
}

void lcd1602_write_char(lcd1602_t *lcd, char c)
{
    lcd_data(lcd, (uint8_t)c);
}

void lcd1602_write_string(lcd1602_t *lcd, const char *str)
{
    while (*str) {
        lcd_data(lcd, (uint8_t)*str++);
    }
}

/* ================= RAW TEST ================= */

void lcd_raw_test(lcd1602_t *lcd)
{
    for (int i = 0; i < 256; i++) {
        lcd_write_byte(lcd, i);
        vTaskDelay(pdMS_TO_TICKS(200));
    }
}
