
#pragma once

#include <stdint.h>
#include "esp_err.h"
#include "driver/i2c.h"
#include "driver/gpio.h"

#ifdef __cplusplus
extern "C" {
#endif

/* ================= STRUCT ================= */

typedef struct {
    i2c_port_t port;
} lcd1602_t;

/* ================= PUBLIC API ================= */

/**
 * @brief Initialize LCD 16x2 with I2C backpack (PCF8574)
 *
 * @param lcd   Pointer to lcd1602_t structure
 * @param port  I2C port number (I2C_NUM_0 / I2C_NUM_1)
 * @param sda   SDA GPIO pin
 * @param scl   SCL GPIO pin
 *
 * @return
 *      - ESP_OK on success
 *      - ESP_FAIL on error
 */
esp_err_t lcd1602_init(lcd1602_t *lcd, i2c_port_t port,
                       gpio_num_t sda, gpio_num_t scl);

/**
 * @brief Clear LCD display
 */
void lcd1602_clear(lcd1602_t *lcd);

/**
 * @brief Set cursor position
 *
 * @param col Column (0–15)
 * @param row Row (0–1)
 */
void lcd1602_set_cursor(lcd1602_t *lcd, uint8_t col, uint8_t row);

/**
 * @brief Write single character
 */
void lcd1602_write_char(lcd1602_t *lcd, char c);
void lcd1602_raw_write(lcd1602_t *lcd, uint8_t data);

/**
 * @brief Write null-terminated string
 */
void lcd1602_write_string(lcd1602_t *lcd, const char *str);

#ifdef __cplusplus
}
#endif

