#include "led_service.h"
#include "esp_log.h"
#include "led_strip.h"
#include "driver/rmt_tx.h"
#include "driver/rmt_encoder.h"
#include "driver/gpio.h"
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"

#define LED_STRIP_GPIO    48
#define LED_STRIP_LENGTH  1

static const char *TAG = "LED_SERVICE";
static led_strip_handle_t strip;
static int idenitfy_update = 0;
static void init_led_strip(void)
{
    led_strip_config_t strip_config = {
        .strip_gpio_num = LED_STRIP_GPIO,
        .max_leds = LED_STRIP_LENGTH,
        .led_model = LED_MODEL_WS2812,
    };

    led_strip_rmt_config_t rmt_config = {
        .resolution_hz = 10 * 1000 * 1000,
        .flags.with_dma = false,
    };

    ESP_ERROR_CHECK(led_strip_new_rmt_device(&strip_config, &rmt_config, &strip));
}

static void blink_led_task(void *pvParameters)
{
    init_led_strip();

    while (1) {
	if(idenitfy_update == 0){
	        led_strip_set_pixel(strip, 0, 0, 255, 0);   // Hijau
	        led_strip_refresh(strip);
	        vTaskDelay(pdMS_TO_TICKS(1000));
	}else{
	        led_strip_set_pixel(strip, 0, 0, 0, 255);   // Biru
	        led_strip_refresh(strip);
	        vTaskDelay(pdMS_TO_TICKS(1000));
	}

        led_strip_clear(strip);
        vTaskDelay(pdMS_TO_TICKS(1000));
    }
}

void led_service_start(void)
{
    ESP_LOGI(TAG, "LED service started");
    xTaskCreate(blink_led_task, "blink_led", 4096, NULL, 5, NULL);
}
